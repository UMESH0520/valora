# Database
DATABASE_URL=sqlite:///./valora.db

# Algorand Blockchain
ALGOD_ADDRESS=https://testnet-api.algonode.cloud
ALGOD_API_TOKEN=a7498e08-d695-40f0-8f94-563fcfb1d80a
ORACLE_MNEMONIC=
APP_ID=0

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
JWT_EXPIRE_MINUTES=60

# Caching (optional - Redis)
REDIS_URL=redis://localhost:6379/0

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Amazon RapidAPI (optional)
AMAZON_RAPIDAPI_KEY=
AMAZON_RAPIDAPI_HOST=
AMAZON_RAPIDAPI_SEARCH_PATH=/product-search
AMAZON_COUNTRY=IN

# WebScrapingAPI E-commerce (optional)
WEBSCRAPINGAPI_ECOM_API_KEY=
AMAZON_DOMAIN=amazon.in

# Flipkart API
FLIPKART_API_KEY=

# Myntra RapidAPI (optional)
MYNTRA_RAPIDAPI_KEY=
MYNTRA_RAPIDAPI_HOST=
MYNTRA_RAPIDAPI_SEARCH_PATH=/search

# Logging
LOG_LEVEL=INFO
